<Window x:Class="AdminTallerNenufar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdminTallerNenufar"
        mc:Ignorable="d"
        Title="Nenúfar Market - Administración de Taller" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="15">
                <TextBlock Text="NENÚFAR" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,5"/>
                <TextBlock Text="Taller de Electrónica" Foreground="#BDC3C7" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button x:Name="BtnNuevoIngreso" 
                        Content="➕ Nuevo Ingreso" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnNuevoIngreso_Click"/>

                <Button x:Name="BtnVerEquipos" 
                        Content="📋 Equipos en Taller" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnVerEquipos_Click"/>

                <Button x:Name="BtnClientes" 
                        Content="👥 Lista de Clientes" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button x:Name="BtnRespaldo" 
                        Content="💾 Crear Respaldo" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnRespaldo_Click"/>

                <Separator Margin="0,20" Background="#3E4F5F" Height="1"/>

                <Button x:Name="BtnSalir" 
                        Content="🚪 Salir" 
                        Height="40" Background="#C0392B" Foreground="White" 
                        BorderThickness="0" FontWeight="Bold"
                        Click="BtnSalir_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Panel de Gestión" FontSize="28" FontWeight="SemiBold" Foreground="#2C3E50"/>
                <Separator Background="#DCDDE1" Margin="0,10,0,0"/>
            </StackPanel>

            <Frame x:Name="MainFrame" 
                   Grid.Row="1" 
                   NavigationUIVisibility="Hidden" 
                   BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>